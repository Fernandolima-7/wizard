{
  "name": "wizard-cashflow",
  "version": "1.0.2",
  "description": "Sistema de fluxo de caixa para escola de inglês Wizard",
  "author": "Fernando Luis da Silva",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "postinstall": "cd client && npm install",
    "clean": "rimraf dist",
    "build": "npm run clean && electron-builder",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "prisma": "^5.7.0"
  },
  "build": {
    "appId": "com.wizard.cashflow",
    "productName": "Wizard CashFlow",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "server/**/*",
      "prisma/**/*",
      "node_modules/**/*",
      "package.json"
    ],
   "extraResources": [
  {
    "from": "server",
    "to": "server"
  },
  {
    "from": "prisma",
    "to": "prisma"
  },
  {
    "from": "node_modules",
    "to": "node_modules"
  }
],
    "asarUnpack": [
  "server/**/*",
  "prisma/**/*",
  "node_modules/**/*"
    ],
    "win": {
      "target": [
  {
    "target": "nsis",
    "arch": ["x64"]
  }
],
      "icon": "frontend/assets/imagens/logo.ico",
        "requestedExecutionLevel": "asInvoker"
    },
    "extraMetadata": {
  "main": "electron/main.js"
},
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
